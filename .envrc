use flake
export AWS_PROFILE=radupopa
export AWS_REGION=eu-central-1

# State backend (must match what bootstrap-tf-backend.sh created)
ACCOUNT_ID=$(aws sts get-caller-identity --profile radupopa --query Account --output text 2>/dev/null || echo "unknown")
export CDKTF_STATE_BUCKET="cdktf-demo-tfstate-${ACCOUNT_ID}"
export CDKTF_STATE_LOCK_TABLE="cdktf-demo-tfstate-lock"

# Terraform 1.14+ doesn't resolve SSO tokens the same way the AWS CLI does.
# Export explicit STS creds so terraform can init the S3 backend.
eval "$(aws configure export-credentials --profile radupopa --format env 2>/dev/null || true)"
